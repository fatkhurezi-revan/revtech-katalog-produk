---
const products = [
  {
    id: 1,
    name: "Sneakers Urban Style",
    category: "Sepatu Pria",
    price: "Rp 350.000",
    image: "https://images.unsplash.com/photo-1542291026-7eec264c27ff?auto=format&fit=crop&q=80&w=800",
    isNew: true
  },
  {
    id: 2,
    name: "Tas Ransel Kanvas",
    category: "Aksesoris",
    price: "Rp 210.000",
    image: "https://images.unsplash.com/photo-1553062407-98eeb64c6a62?auto=format&fit=crop&q=80&w=800",
    isNew: false
  },
  {
    id: 3,
    name: "Kacamata Hitam Klasik",
    category: "Aksesoris Pria",
    price: "Rp 125.000",
    image: "https://images.unsplash.com/photo-1511499767150-a48a237f0083?auto=format&fit=crop&q=80&w=800",
    isNew: false
  },
  {
    id: 4,
    name: "Smartwatch Active",
    category: "Elektronik",
    price: "Rp 850.000",
    image: "https://images.unsplash.com/photo-1523275335684-37898b6baf30?auto=format&fit=crop&q=80&w=800",
    isNew: true
  },
  {
    id: 5,
    name: "Botol Minum Stainless",
    category: "Peralatan",
    price: "Rp 95.000",
    image: "https://images.unsplash.com/photo-1602143407151-7111542de6e8?auto=format&fit=crop&q=80&w=800",
    isNew: false
  },
  {
    id: 6,
    name: "Headphone Bluetooth",
    category: "Elektronik",
    price: "Rp 450.000",
    image: "https://images.unsplash.com/photo-1505740420928-5e560c06d30e?auto=format&fit=crop&q=80&w=800",
    isNew: true
  }
];

const waText = "Halo RevTech, saya tertarik untuk memesan pembuatan website Paket Hemat (Template Katalog Produk). Boleh bantu panduannya untuk langkah selanjutnya?";
---
<section id="katalog" class="py-16 lg:py-24 bg-gray-50 border-b border-gray-200">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h2 class="text-4xl font-extrabold text-slate-900 mb-4 tracking-tight">Katalog Produk</h2>
      <div class="w-16 h-1 bg-slate-900 mx-auto"></div>
    </div>
    
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
      {products.map((product) => (
        <div class="group bg-white flex flex-col h-full border border-gray-200 rounded-lg hover:border-gray-400 transition-colors duration-200 overflow-hidden">
          <!-- Image Container -->
          <div class="relative h-64 sm:h-72 overflow-hidden bg-gray-100">
            <img 
              src={product.image} 
              alt={product.name} 
              class="w-full h-full object-cover transition-opacity duration-300 hover:opacity-90"
              loading="lazy"
            />
            {product.isNew && (
              <div class="absolute top-4 left-4 bg-slate-900 text-white text-[10px] font-bold px-3 py-1.5 uppercase tracking-widest rounded-sm">
                Terbaru
              </div>
            )}
          </div>
          
          <!-- Content Container -->
          <div class="p-6 flex flex-col flex-grow relative bg-white border-t border-gray-100">
            <span class="text-[10px] font-bold text-gray-500 mb-2 tracking-widest uppercase">{product.category}</span>
            <div class="flex flex-col gap-2 mb-6">
              <h3 class="text-lg font-bold text-slate-900 leading-tight">
                {product.name}
              </h3>
              <span class="text-lg font-extrabold text-slate-900">{product.price}</span>
            </div>
            
            <!-- Button -->
            <div class="mt-auto">
               <a href={`https://wa.me/6281290018819?text=${encodeURIComponent(waText)}`} target="_blank" rel="noopener noreferrer" class="bg-white border border-slate-900 text-slate-900 rounded-md font-bold py-3 w-full flex items-center justify-center gap-2 hover:bg-gray-50 transition-colors duration-200">
                 <span>Beli Sekarang</span>
               </a>
            </div>
          </div>
        </div>
      ))}
    </div>
    
    <div class="mt-16 text-center">
      <a href={`https://wa.me/6281290018819?text=${encodeURIComponent(waText)}`} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-slate-900 font-bold text-sm uppercase tracking-widest hover:text-gray-600 transition-colors duration-200">
        <span class="border-b-2 border-slate-900 pb-1">Lihat Semua Katalog</span>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </div>
</section>
