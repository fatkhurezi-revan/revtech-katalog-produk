---
const products = [
  {
    id: 1,
    name: "Sneakers Urban Style",
    category: "Sepatu Pria",
    price: "Rp 350.000",
    image: "https://images.unsplash.com/photo-1542291026-7eec264c27ff?auto=format&fit=crop&q=80&w=800",
    isNew: true
  },
  {
    id: 2,
    name: "Tas Ransel Kanvas",
    category: "Aksesoris",
    price: "Rp 210.000",
    image: "https://images.unsplash.com/photo-1553062407-98eeb64c6a62?auto=format&fit=crop&q=80&w=800",
    isNew: false
  },
  {
    id: 3,
    name: "Kacamata Hitam Klasik",
    category: "Aksesoris Pria",
    price: "Rp 125.000",
    image: "https://images.unsplash.com/photo-1511499767150-a48a237f0083?auto=format&fit=crop&q=80&w=800",
    isNew: false
  },
  {
    id: 4,
    name: "Smartwatch Active",
    category: "Elektronik",
    price: "Rp 850.000",
    image: "https://images.unsplash.com/photo-1523275335684-37898b6baf30?auto=format&fit=crop&q=80&w=800",
    isNew: true
  },
  {
    id: 5,
    name: "Botol Minum Stainless",
    category: "Peralatan",
    price: "Rp 95.000",
    image: "https://images.unsplash.com/photo-1602143407151-7111542de6e8?auto=format&fit=crop&q=80&w=800",
    isNew: false
  },
  {
    id: 6,
    name: "Headphone Bluetooth",
    category: "Elektronik",
    price: "Rp 450.000",
    image: "https://images.unsplash.com/photo-1505740420928-5e560c06d30e?auto=format&fit=crop&q=80&w=800",
    isNew: true
  }
];

const waText = "Halo RevTech, saya tertarik untuk memesan pembuatan website Paket Hemat Katalog Produk. Boleh bantu panduannya untuk langkah selanjutnya?";
---
<section id="katalog" class="py-24 bg-white relative">
  <!-- Decorative Background Elements -->
  <div class="absolute top-0 left-0 w-full h-full overflow-hidden pointer-events-none opacity-30">
    <div class="absolute -top-24 -right-24 w-96 h-96 rounded-full bg-blue-50"></div>
    <div class="absolute top-1/2 -left-24 w-72 h-72 rounded-full bg-orange-50"></div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="text-center max-w-3xl mx-auto mb-16 opacity-0 animate-fade-in-up">
      <h2 class="text-4xl md:text-5xl font-extrabold text-dark mb-6">Koleksi Produk Pilihan</h2>
      <div class="w-24 h-1.5 bg-gradient-to-r from-primary to-secondary mx-auto rounded-full mb-6"></div>
      <p class="text-gray-600 text-lg md:text-xl">Temukan berbagai macam produk berkualitas dengan harga terbaik. Jelajahi katalog eksklusif kami di bawah ini.</p>
    </div>
    
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-10">
      {products.map((product, index) => (
        <div class="group bg-white rounded-3xl overflow-hidden shadow-sm hover:shadow-2xl hover:shadow-blue-900/10 transition-all duration-500 border border-gray-100 hover:border-blue-100 hover:-translate-y-3 flex flex-col h-full relative z-10 opacity-0 animate-fade-in-up" style={`animation-delay: ${0.2 + (index * 0.1)}s;`}>
          <!-- Image Container -->
          <div class="relative h-72 overflow-hidden bg-gray-50">
            <img 
              src={product.image} 
              alt={product.name} 
              class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700 ease-out"
              loading="lazy"
            />
            {product.isNew && (
              <div class="absolute top-4 left-4 bg-gradient-to-r from-orange-400 to-red-500 text-white text-xs font-bold px-3.5 py-1.5 rounded-full uppercase tracking-wider shadow-lg transform -rotate-2 group-hover:rotate-0 transition-transform">
                Terbaru
              </div>
            )}
            <!-- Overlay gradients and actions -->
            <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-black/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
            
            <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-all duration-500">
               <a href={`https://wa.me/6281290018819?text=${encodeURIComponent(waText)}`} target="_blank" rel="noopener noreferrer" class="bg-white/95 backdrop-blur-md text-dark font-bold px-8 py-3.5 rounded-full hover:bg-primary hover:text-white transition-all transform translate-y-8 group-hover:translate-y-0 duration-500 shadow-xl flex items-center gap-2 group/btn">
                 <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-green-500 group-hover/btn:text-white transition-colors" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.015c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/>
                </svg>
                 Beli via WA
               </a>
            </div>
          </div>
          
          <!-- Content Container -->
          <div class="p-8 flex flex-col flex-grow relative bg-white">
            <span class="text-xs font-bold text-primary mb-2 tracking-widest uppercase bg-blue-50 inline-block px-2 py-1 rounded w-max">{product.category}</span>
            <h3 class="text-2xl font-bold text-dark mb-3 group-hover:text-primary transition-colors">{product.name}</h3>
            
            <div class="mt-auto pt-6 border-t border-gray-100 flex items-center justify-between">
              <span class="text-xl font-extrabold text-transparent bg-clip-text bg-gradient-to-r from-gray-900 to-gray-700">{product.price}</span>
              
              <div class="w-10 h-10 rounded-full bg-gray-50 flex items-center justify-center group-hover:bg-green-50 transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-gray-400 group-hover:text-green-500 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                </svg>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
    
    <div class="mt-20 text-center opacity-0 animate-fade-in-up" style="animation-delay: 0.8s;">
      <a href={`https://wa.me/6281290018819?text=${encodeURIComponent(waText)}`} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-3 px-10 py-5 border-2 border-primary text-primary hover:bg-primary hover:text-white rounded-full font-bold text-lg transition-all duration-300 hover:shadow-xl hover:shadow-blue-500/20 group">
        <span>Lihat Semua Koleksi di WhatsApp</span>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 group-hover:translate-x-2 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </div>
</section>
