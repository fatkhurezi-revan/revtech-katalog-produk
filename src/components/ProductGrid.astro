---
const products = [
  {
    id: 1,
    name: "Sneakers Urban Style",
    category: "Sepatu Pria",
    price: "Rp 350.000",
    image: "https://images.unsplash.com/photo-1542291026-7eec264c27ff?auto=format&fit=crop&q=80&w=800",
    isNew: true
  },
  {
    id: 2,
    name: "Tas Ransel Kanvas",
    category: "Aksesoris",
    price: "Rp 210.000",
    image: "https://images.unsplash.com/photo-1553062407-98eeb64c6a62?auto=format&fit=crop&q=80&w=800",
    isNew: false
  },
  {
    id: 3,
    name: "Kacamata Hitam Klasik",
    category: "Aksesoris Pria",
    price: "Rp 125.000",
    image: "https://images.unsplash.com/photo-1511499767150-a48a237f0083?auto=format&fit=crop&q=80&w=800",
    isNew: false
  },
  {
    id: 4,
    name: "Smartwatch Active",
    category: "Elektronik",
    price: "Rp 850.000",
    image: "https://images.unsplash.com/photo-1523275335684-37898b6baf30?auto=format&fit=crop&q=80&w=800",
    isNew: true
  },
  {
    id: 5,
    name: "Botol Minum Stainless",
    category: "Peralatan",
    price: "Rp 95.000",
    image: "https://images.unsplash.com/photo-1602143407151-7111542de6e8?auto=format&fit=crop&q=80&w=800",
    isNew: false
  },
  {
    id: 6,
    name: "Headphone Bluetooth",
    category: "Elektronik",
    price: "Rp 450.000",
    image: "https://images.unsplash.com/photo-1505740420928-5e560c06d30e?auto=format&fit=crop&q=80&w=800",
    isNew: true
  }
];

const waText = "Halo RevTech, saya tertarik untuk memesan pembuatan website Paket Hemat Katalog Produk. Boleh bantu panduannya untuk langkah selanjutnya?";
---
<section id="katalog" class="py-24 bg-white relative">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="text-center max-w-3xl mx-auto mb-16 opacity-0 animate-fade-in-up">
      <h2 class="text-4xl md:text-5xl font-extrabold text-black mb-6 tracking-tight">Koleksi Produk Pilihan</h2>
      <div class="w-24 h-1 bg-black mx-auto mb-6"></div>
    </div>
    
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-10">
      {products.map((product, index) => (
        <div class="group bg-white overflow-hidden transition-all duration-500 border border-transparent hover:border-gray-200 flex flex-col h-full relative z-10 opacity-0 animate-fade-in-up hover:shadow-2xl hover:shadow-black/5" style={`animation-delay: ${0.2 + (index * 0.1)}s;`}>
          <!-- Image Container -->
          <div class="relative h-[400px] overflow-hidden bg-gray-50">
            <img 
              src={product.image} 
              alt={product.name} 
              class="w-full h-full object-cover transform group-hover:scale-105 transition-transform duration-700 ease-out"
              loading="lazy"
            />
            {product.isNew && (
              <div class="absolute top-4 left-4 bg-black text-white text-[10px] font-bold px-3 py-1.5 uppercase tracking-widest">
                Terbaru
              </div>
            )}
            
            <div class="absolute inset-0 bg-black/10 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
            
            <!-- Minimalist Button over Image -->
            <div class="absolute inset-x-0 bottom-6 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-all duration-500 transform translate-y-4 group-hover:translate-y-0">
               <a href={`https://wa.me/6281290018819?text=${encodeURIComponent(waText)}`} target="_blank" rel="noopener noreferrer" class="bg-black text-white font-bold px-10 py-4 shadow-xl flex items-center gap-3 hover:bg-gray-800 transition-colors w-[85%] justify-center">
                 <span>Beli via WhatsApp</span>
                 <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.015c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/>
                 </svg>
               </a>
            </div>
          </div>
          
          <!-- Content Container -->
          <div class="p-6 flex flex-col flex-grow relative bg-white border-t-0">
            <span class="text-[10px] font-bold text-gray-400 mb-2 tracking-widest uppercase">{product.category}</span>
            <div class="flex items-start justify-between gap-4">
              <h3 class="text-lg font-bold text-black leading-tight group-hover:text-gray-600 transition-colors">
                {product.name}
              </h3>
              <span class="text-lg font-extrabold text-black whitespace-nowrap">{product.price}</span>
            </div>
          </div>
        </div>
      ))}
    </div>
    
    <div class="mt-20 text-center opacity-0 animate-fade-in-up" style="animation-delay: 0.8s;">
      <a href={`https://wa.me/6281290018819?text=${encodeURIComponent(waText)}`} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-3 px-10 py-5 border border-black text-black hover:bg-black hover:text-white font-bold text-sm uppercase tracking-widest transition-all duration-300 group">
        <span>Lihat Semua Katalog</span>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 group-hover:translate-x-2 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </div>
</section>
