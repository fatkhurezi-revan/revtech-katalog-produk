---
const features = [
  {
    title: "Kualitas Premium",
    description: "Semua produk kami dipilih dengan cermat melalui proses Quality Control yang ketat untuk memastikan standar kualitas terbaik.",
    icon: `<svg class="w-8 h-8 text-white group-hover:animate-pulse" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" /></svg>`,
    color: "from-blue-500 to-cyan-400"
  },
  {
    title: "Pengiriman Cepat",
    description: "Kami bekerja sama dengan ekspedisi terkemuka dan terpercaya untuk memastikan pesanan Anda tiba tepat waktu dengan aman.",
    icon: `<svg class="w-8 h-8 text-white group-hover:animate-bounce" style="animation-duration: 2s;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>`,
    color: "from-orange-500 to-amber-400"
  },
  {
    title: "Pesan via WA",
    description: "Transaksi menjadi jauh lebih mudah, cepat, dan personal langsung melalui WhatsApp tanpa perlu mengisi form yang rumit.",
    icon: `<svg class="w-8 h-8 text-white group-hover:rotate-12 transition-transform duration-300" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.015c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/></svg>`,
    color: "from-green-500 to-emerald-400"
  }
];
---
<section id="keunggulan" class="py-24 bg-gray-50 border-y border-gray-100 relative overflow-hidden">
  <!-- Subtle pattern background -->
  <div class="absolute inset-0 opacity-[0.03] bg-[radial-gradient(#3b82f6_1px,transparent_1px)] [background-size:20px_20px]"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="text-center max-w-3xl mx-auto mb-20 opacity-0 animate-fade-in-up">
      <span class="text-primary font-bold tracking-wider uppercase text-sm mb-2 block">Keunggulan Layanan</span>
      <h2 class="text-4xl md:text-5xl font-extrabold text-dark mb-6">Mengapa Memilih Kami?</h2>
      <p class="text-gray-600 text-lg md:text-xl">Komitmen kami adalah memberikan pengalaman berbelanja online terbaik untuk Anda.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
      {features.map((feature, index) => (
        <div class="bg-white rounded-3xl p-10 shadow-sm hover:shadow-2xl hover:shadow-blue-900/5 transition-all duration-500 border border-gray-100 group relative opacity-0 animate-fade-in-up transform hover:-translate-y-4" style={`animation-delay: ${0.3 + (index * 0.2)}s;`}>
          <!-- Hover Gradient Background -->
          <div class="absolute inset-0 bg-gradient-to-br from-primary/[0.03] to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 rounded-3xl pointer-events-none"></div>
          
          <!-- Icon Container -->
          <div class={`w-20 h-20 rounded-2xl bg-gradient-to-br ${feature.color} flex items-center justify-center mb-8 shadow-lg shadow-gray-200 group-hover:scale-110 group-hover:rotate-3 transition-all duration-500`}>
            <Fragment set:html={feature.icon} />
          </div>
          
          <!-- Content -->
          <h3 class="text-2xl font-bold text-dark mb-4 relative z-10 group-hover:text-primary transition-colors">{feature.title}</h3>
          <p class="text-gray-600 leading-relaxed relative z-10 text-lg">{feature.description}</p>
          
          <!-- Decorative Corner Element -->
          <div class="absolute -bottom-4 -right-4 w-24 h-24 bg-gray-50 rounded-full opacity-0 group-hover:opacity-100 transition-opacity duration-500 -z-10 group-hover:scale-150 ease-out"></div>
        </div>
      ))}
    </div>
  </div>
</section>
