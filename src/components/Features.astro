---
<section id="keunggulan" class="py-16 lg:py-24 bg-white border-b border-gray-100">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
      {features.map((feature) => (
        <div class="bg-white p-6 sm:p-8 rounded-lg border border-gray-200 hover:border-gray-400 transition-colors duration-200">
          <div class="w-12 h-12 bg-slate-900 rounded-md flex items-center justify-center mb-6">
            <Fragment set:html={feature.icon} />
          </div>
          
          <h3 class="text-xl font-bold text-slate-900 mb-3">{feature.title}</h3>
          <p class="text-gray-500 leading-relaxed text-sm">{feature.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
