---
const features = [
  {
    title: "Kualitas Premium",
    description: "Semua produk kami dipilih dengan cermat untuk memastikan kualitas terbaik.",
    icon: `<svg class="w-8 h-8 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" /></svg>`
  },
  {
    title: "Pengiriman Cepat",
    description: "Kami bekerja sama dengan ekspedisi terpercaya untuk pengiriman tepat waktu.",
    icon: `<svg class="w-8 h-8 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>`
  },
  {
    title: "Pesan via WA",
    description: "Transaksi lebih mudah, cepat, dan personal langsung melalui WhatsApp.",
    icon: `<svg class="w-8 h-8 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" /></svg>`
  }
];
---
<section id="keunggulan" class="py-20 bg-gray-50 border-y border-gray-100 relative overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h2 class="text-3xl md:text-4xl font-bold text-dark mb-4">Mengapa Memilih Kami?</h2>
      <p class="text-gray-600 text-lg">Komitmen kami adalah memberikan pengalaman berbelanja terbaik untuk Anda.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
      {features.map((feature) => (
        <div class="bg-white rounded-2xl p-8 shadow-sm hover:shadow-xl transition-shadow duration-300 border border-gray-100 group relative">
          <div class="absolute inset-0 bg-gradient-to-br from-primary/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity rounded-2xl"></div>
          <div class="w-16 h-16 rounded-xl bg-gradient-to-br from-primary to-secondary flex items-center justify-center mb-6 shadow-md transform group-hover:rotate-6 transition-transform">
            <Fragment set:html={feature.icon} />
          </div>
          <h3 class="text-xl font-bold text-dark mb-3 relative z-10">{feature.title}</h3>
          <p class="text-gray-600 leading-relaxed relative z-10">{feature.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
