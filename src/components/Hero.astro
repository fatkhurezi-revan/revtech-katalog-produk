---
const bgImagesRow1 = [
  "https://images.unsplash.com/photo-1542291026-7eec264c27ff?auto=format&fit=crop&q=80&w=400",
  "https://images.unsplash.com/photo-1523275335684-37898b6baf30?auto=format&fit=crop&q=80&w=400",
  "https://images.unsplash.com/photo-1505740420928-5e560c06d30e?auto=format&fit=crop&q=80&w=400",
  "https://images.unsplash.com/photo-1553062407-98eeb64c6a62?auto=format&fit=crop&q=80&w=400",
  "https://images.unsplash.com/photo-1584916201218-f4242ceb4809?auto=format&fit=crop&q=80&w=400",
  "https://images.unsplash.com/photo-1627384113743-6bd5a479fffd?auto=format&fit=crop&q=80&w=400",
];

const bgImagesRow2 = [
  "https://images.unsplash.com/photo-1602143407151-7111542de6e8?auto=format&fit=crop&q=80&w=400",
  "https://images.unsplash.com/photo-1593998066526-65fcab3021a2?auto=format&fit=crop&q=80&w=400",
  "https://images.unsplash.com/photo-1511499767150-a48a237f0083?auto=format&fit=crop&q=80&w=400",
  "https://images.unsplash.com/photo-1583394838336-acd977736f90?auto=format&fit=crop&q=80&w=400",
  "https://images.unsplash.com/photo-1542291026-7eec264c27ff?auto=format&fit=crop&q=80&w=400",
  "https://images.unsplash.com/photo-1523275335684-37898b6baf30?auto=format&fit=crop&q=80&w=400",
];
---
<section id="hero" class="relative pt-28 pb-16 lg:pt-48 lg:pb-32 bg-white min-h-[80vh] flex items-center border-b border-gray-100 overflow-hidden">
  
  <!-- Static Background Collage (High Performance, No Animation) -->
  <div class="absolute inset-0 z-0 overflow-hidden opacity-[0.03] transform -skew-y-6 scale-150 md:scale-125 grayscale pointer-events-none">
    <div class="absolute inset-0 flex flex-col justify-center gap-2 md:gap-4 h-full">
      <div class="flex gap-2 md:gap-4 min-w-max justify-center -ml-10 md:-ml-20">
        {bgImagesRow1.map(img => (
          <div class="w-32 h-32 md:w-64 md:h-64 flex-shrink-0 rounded-xl md:rounded-2xl overflow-hidden bg-slate-900">
            <img src={img} alt="Latar belakang produk" class="w-full h-full object-cover" loading="lazy" />
          </div>
        ))}
      </div>
      <div class="flex gap-2 md:gap-4 min-w-max justify-center -ml-20 md:-ml-40">
        {bgImagesRow2.map(img => (
          <div class="w-32 h-32 md:w-64 md:h-64 flex-shrink-0 rounded-xl md:rounded-2xl overflow-hidden bg-slate-900">
            <img src={img} alt="Latar belakang produk" class="w-full h-full object-cover" loading="lazy" />
          </div>
        ))}
      </div>
    </div>
  </div>

  <div class="absolute inset-0 z-0 bg-gradient-to-t from-white via-white/80 to-white/60 pointer-events-none"></div>

  <!-- Hero Content -->
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 text-center mt-8 md:mt-0">
    <div class="inline-flex items-center gap-2 py-1.5 px-4 rounded-full bg-white border border-gray-200 mb-4 md:mb-6">
      <div class="relative flex h-2 w-2">
        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
        <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
      </div>
      <span class="text-slate-900 text-xs md:text-sm font-bold">Katalog Produk Eksklusif</span>
    </div>
    
    <!-- HANYA ADA 1 H1 -->
    <h1 class="text-4xl sm:text-5xl md:text-7xl font-extrabold text-slate-900 tracking-tight mb-6 md:mb-8 leading-tight">
      Pamerkan Produk <br class="hidden sm:block" />
      <span class="text-gray-400">Lebih Elegan.</span>
    </h1>
    
    <p class="mt-2 md:mt-4 text-lg md:text-xl text-gray-500 max-w-2xl mx-auto mb-8 md:mb-10 leading-relaxed font-medium px-2">
      Fokuskan perhatian pelanggan langsung pada produk Anda. Desain bersih, lapang, dan langsung pada intinya.
    </p>
    
    <div class="flex flex-col sm:flex-row justify-center gap-3 md:gap-4 px-4 sm:px-0">
      <a href="https://wa.me/6281290018819?text=Halo%20RevTech,%20saya%20tertarik%20untuk%20memesan%20pembuatan%20website%20Paket%20Hemat%20Katalog%20Produk.%20Boleh%20bantu%20panduannya%20untuk%20langkah%20selanjutnya?" target="_blank" rel="noopener noreferrer" class="w-full sm:w-auto px-8 md:px-10 py-3.5 md:py-4 bg-slate-900 text-white rounded-md font-bold text-base md:text-lg hover:bg-slate-800 transition-colors duration-200 flex items-center justify-center gap-2 group">
        Pesan Sekarang 
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 md:h-5 md:w-5 group-hover:translate-x-1 transition-transform duration-200" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" />
        </svg>
      </a>
      <a href="#katalog" class="w-full sm:w-auto px-8 md:px-10 py-3.5 md:py-4 bg-white text-slate-900 border border-gray-300 rounded-md font-bold text-base md:text-lg hover:border-slate-400 hover:bg-gray-50 transition-colors duration-200">
        Eksplorasi
      </a>
    </div>
  </div>
</section>
